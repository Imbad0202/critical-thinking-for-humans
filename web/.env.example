# Vercel Cron sends this value as `Authorization: Bearer …`.
# Generate a long random value in the Vercel project; never commit the real one.
CRON_SECRET=

# Vercel deployments may receive project auth through OIDC. A local CLI upload
# normally needs the Production Blob token (or an actually injected
# VERCEL_OIDC_TOKEN); `vercel env pull` does not create an OIDC credential.
BLOB_READ_WRITE_TOKEN=

DAILY_TIME_ZONE=Asia/Taipei
DAILY_CONTENT_PROVIDER=blob
DAILY_BLOB_PREFIX=daily
DAILY_PUBLISH_OFFSET_DAYS=1
